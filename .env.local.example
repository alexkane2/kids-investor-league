# Alpaca API credentials — used ONLY by the serverless function in api/prices.js.
# These are read server-side via process.env and are never exposed to the browser.
# Do NOT add a VITE_ prefix: VITE_-prefixed vars get bundled into client-side JS.
#
# Local dev: copy this file to .env.local and fill in your keys.
# Production (Vercel): set these in the Vercel dashboard under Settings → Environment Variables.
ALPACA_KEY=your_alpaca_key_here
ALPACA_SECRET=your_alpaca_secret_here
